# Prediqt — local environment template
#
# Copy this file to `.env` (same folder) and fill in values.
# `.env` is gitignored — never commit real keys.
#
# Everything below is optional while USE_SUPABASE=false (default).

# ─── Backend feature flag ──────────────────────────────────────────────────
# false  → data stored in local JSON files (current behavior)
# true   → data stored in Supabase Postgres (Phase 1 onward)
USE_SUPABASE=false

# ─── Supabase project credentials ──────────────────────────────────────────
# Found at: Project → Settings → API on your Supabase dashboard.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=

# Service-role key — bypasses Row-Level Security. Used ONLY by server-side
# workers (Stripe webhooks, prediction-scoring cron). NEVER ship to client.
# Leave blank for now unless you're running those workers locally.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Local dev "acting as" user ────────────────────────────────────────────
# Before auth is wired (Phase 2), your local Streamlit needs to pretend to
# be some specific user. Create one manually (see SUPABASE_SETUP.md step 4)
# and paste their uuid here. All DB reads/writes will be scoped to this user.
DEV_USER_ID=

# ─── Stripe (Phase 3 — not needed yet) ─────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_PRICE_ID=
